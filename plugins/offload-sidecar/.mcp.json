{
  "mcpServers": {
    "offload-sidecar": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/offload_sidecar.py"],
      "cwd": "${CLAUDE_PROJECT_DIR}",
      "env": {
        "OLLAMA_HOST": "${user_config.ollama_host}",
        "OLLAMA_MODEL": "${user_config.ollama_model}",
        "OLLAMA_NUM_CTX": "${user_config.num_ctx}",
        "OLLAMA_FAST_HOST": "${user_config.fast_ollama_host}",
        "OLLAMA_FAST_MODEL": "${user_config.fast_ollama_model}",
        "OLLAMA_FAST_NUM_CTX": "${user_config.fast_num_ctx}",
        "OLLAMA_TLS_CA": "${user_config.tls_ca_file}",
        "AGY_BIN": "${user_config.agy_bin}",
        "AGY_FLASH_MODEL": "${user_config.agy_flash_model}",
        "AGY_PRO_MODEL": "${user_config.agy_pro_model}",
        "AGY_FLASH_PER_5H": "${user_config.agy_flash_per_5h}",
        "AGY_FLASH_PER_WEEK": "${user_config.agy_flash_per_week}",
        "AGY_PRO_PER_5H": "${user_config.agy_pro_per_5h}",
        "AGY_PRO_PER_WEEK": "${user_config.agy_pro_per_week}",
        "SIDECAR_ROOT": "${CLAUDE_PROJECT_DIR}"
      }
    }
  }
}
